---
// Selector de idioma de la raíz. Detecta el idioma del navegador y redirige a
// /es/ o /en/. Solo actúa en "/" — entrar directo a /es o /en se respeta.
// El sitio es estático (GitHub Pages), así que la detección es en cliente.
import { defaultLocale, locales } from '../i18n';
---

<!doctype html>
<html lang={defaultLocale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Taller Martínez</title>
    <link rel="canonical" href="https://tallermartinez.net/" />
    <script is:inline define:vars={{ defaultLocale, supported: locales }}>
      (function () {
        var langs =
          navigator.languages && navigator.languages.length
            ? navigator.languages
            : [navigator.language || defaultLocale];
        var pick = defaultLocale;
        for (var i = 0; i < langs.length; i++) {
          var code = (langs[i] || '').slice(0, 2).toLowerCase();
          if (supported.indexOf(code) !== -1) {
            pick = code;
            break;
          }
        }
        location.replace('/' + pick + '/');
      })();
    </script>
    <!-- Fallback sin JavaScript: idioma por defecto. -->
    <noscript>
      <meta http-equiv="refresh" content="0; url=/es/" />
    </noscript>
  </head>
  <body>
    <p>Taller Martínez — <a href="/es/">Español</a> · <a href="/en/">English</a></p>
  </body>
</html>
