---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Taller Martínez · Informática para tu negocio',
  description = 'El informático de confianza de tu negocio. Web, datos, copias de seguridad y redes sociales para negocios locales, en manos de una sola persona.',
} = Astro.props;

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="color-scheme" content="dark" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={base} aria-label="Taller Martínez">
          <span class="mark"><span class="chevron">&gt;</span><span class="m">M</span></span>
          <span class="brand-name">Taller Martínez</span>
        </a>
        <nav class="nav">
          <a href="#servicios">Servicios</a>
          <a href="#como-trabajo">Cómo trabajo</a>
          <a class="nav-cta" href="#contacto">Hablemos</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <span>© {year} Taller Martínez · Alberto Martínez</span>
        <span>
          <a href="mailto:hola@tallermartinez.dev">hola@tallermartinez.dev</a> ·
          <a href="https://vontus.dev" rel="noopener" target="_blank">vontus.dev</a>
        </span>
      </div>
    </footer>
  </body>
</html>
