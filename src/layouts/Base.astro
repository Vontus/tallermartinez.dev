---
import '../styles/global.css';
import { getContent, locales, type Locale } from '../i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const c = getContent(locale);

const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(c.meta.ogImage, Astro.site).href;

// URLs por idioma (rutas /es/ y /en/) + x-default al selector de la raíz.
const localeUrl = (l: Locale) => new URL(`${l}/`, Astro.site).href;
const xDefault = new URL('/', Astro.site).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Taller Martínez',
  description: c.meta.description,
  url: canonical,
  image: ogImage,
  email: c.contact.email,
  priceRange: '€€',
  founder: { '@type': 'Person', name: 'Alberto Martínez' },
  sameAs: ['https://vontus.dev'],
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Torrevieja',
    addressRegion: 'Alicante',
    addressCountry: 'ES',
  },
  areaServed: c.meta.areaServed.map((name) => ({ '@type': 'AdministrativeArea', name })),
  knowsAbout: c.meta.knowsAbout,
};
---

<!doctype html>
<html lang={c.meta.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{c.meta.title}</title>
    <meta name="description" content={c.meta.description} />
    <link rel="canonical" href={canonical} />
    {locales.map((l) => <link rel="alternate" hreflang={l} href={localeUrl(l)} />)}
    <link rel="alternate" hreflang="x-default" href={xDefault} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#16181b" />

    <!-- Geo / local -->
    <meta name="geo.region" content="ES-A" />
    <meta name="geo.placename" content="Torrevieja" />
    <meta name="geo.position" content="37.978;-0.682" />
    <meta name="ICBM" content="37.978, -0.682" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Taller Martínez" />
    <meta property="og:title" content={c.meta.title} />
    <meta property="og:description" content={c.meta.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={c.meta.ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={c.meta.title} />
    <meta name="twitter:description" content={c.meta.description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a class="brand" href={`${base}${locale}/`} aria-label="Taller Martínez">
          <img class="logo-mark" src={`${base}logo.svg`} width="32" height="32" alt="" />
          <img class="wordmark" src={`${base}wordmark.svg`} alt="Taller Martínez" />
        </a>
        <nav class="nav">
          <a href="#servicios">{c.nav.services}</a>
          <a href="#como-trabajo">{c.nav.how}</a>
          <a class="nav-cta" href="#contacto">{c.nav.cta}</a>
          <span class="lang" aria-label={c.nav.langLabel}>
            {
              locales.map((l) => (
                <a href={`${base}${l}/`} class={l === locale ? 'active' : ''} hreflang={l}>
                  {l.toUpperCase()}
                </a>
              ))
            }
          </span>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <span>© {year} Taller Martínez · {c.footer.location}</span>
        <span>
          <a href={`mailto:${c.contact.email}`}>{c.contact.email}</a> ·
          <a href="https://vontus.dev" rel="noopener" target="_blank">vontus.dev</a>
        </span>
      </div>
    </footer>
  </body>
</html>
